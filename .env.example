# ═══════════════════════════════════════════════════════════════════════════════
# Job Apply Agent - Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# NOTE: Your personal data (name, skills, experience) is NOT stored here.
#       It's auto-extracted from your resume PDF into data/profile.json.
#       Just place your resume at the path below and run `job-agent init`.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Resume Path ─────────────────────────────────────────────────────────────
# Point this to your resume PDF. The agent will parse it automatically
# and keep a vectorized copy for matching. Update your PDF = agent auto-updates.
RESUME_PATH=data/resume.pdf

# ─── Ollama Configuration ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT=120

# ─── Job Search Preferences ──────────────────────────────────────────────────
JOB_TITLES=Software Engineer,Backend Developer,Full Stack Developer
JOB_LOCATIONS=Remote,New York,San Francisco
JOB_MIN_SALARY=80000
JOB_EXPERIENCE_LEVEL=mid
JOB_TYPES=full-time
JOB_EXCLUDED_COMPANIES=
JOB_KEYWORDS=

# ─── Application Settings ────────────────────────────────────────────────────
APP_AUTO_SUBMIT=false
APP_MAX_APPLICATIONS_PER_DAY=10
APP_SEARCH_INTERVAL_MINUTES=60
APP_MIN_MATCH_SCORE=0.6
APP_HEADLESS=true

# ─── Infrastructure ──────────────────────────────────────────────────────────
DB_PATH=data/applications.db
VECTORDB_PATH=data/vectordb
LOG_LEVEL=INFO
SERVER_PORT=8000

# ─── Notifications (Optional) ────────────────────────────────────────────────
NOTIFICATIONS_ENABLED=false
NOTIFY_TELEGRAM_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_PASSWORD=

# ─── LangSmith (Optional - for tracing/observability) ────────────────────────
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=job-apply-agent
LANGSMITH_TRACING_V2=true
